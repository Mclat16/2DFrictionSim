#!/bin/bash
#SBATCH --nodes={{ nodes }}
#SBATCH --ntasks-per-node={{ ntasks_per_node }}
#SBATCH --cpus-per-task={{ cpus_per_task }}
#SBATCH --time={{ walltime }}
{% if array_size > 1 %}
#SBATCH --array=1-{{ array_size }}
#SBATCH --output={{ log_dir }}/{{ job_name }}_%a_out.txt
#SBATCH --error={{ log_dir }}/{{ job_name }}_%a_err.txt
{% else %}
#SBATCH --output={{ log_dir }}/{{ job_name }}_out.txt
#SBATCH --error={{ log_dir }}/{{ job_name }}_err.txt
{% endif %}
#SBATCH --job-name={{ job_name }}
{% if partition %}
#SBATCH --partition={{ partition }}
{% endif %}
{% if account %}
#SBATCH --account={{ account }}
{% endif %}
{% if mem %}
#SBATCH --mem={{ mem }}
{% endif %}

module purge
{% for mod in modules %}
module load {{ mod }}
{% endfor %}

{% if array_size > 1 %}
TASK_ID=${SLURM_ARRAY_TASK_ID}
{% else %}
TASK_ID=1
{% endif %}

SCRIPT_PATH=$(sed -n "${TASK_ID}p" {{ manifest_file }})
SCRIPT_DIR=$(dirname "$SCRIPT_PATH")
SIM_PATH=$(dirname "$SCRIPT_DIR")

if [ -z "$SCRIPT_PATH" ]; then
    echo "Error: No script path for index ${TASK_ID}"
    exit 1
fi

{% if use_tmpdir %}
SCRATCH={{ scratch_dir }}/friction2d_${SLURM_JOB_ID}
mkdir -p $SCRATCH/${SIM_PATH}
rsync -av --exclude='*.lammpstrj' {{ base_dir }}/${SIM_PATH}/ $SCRATCH/${SIM_PATH}/
cd $SCRATCH
{% else %}
cd {{ base_dir }}
{% endif %}

if [[ "$SCRIPT_PATH" == *slide*.in ]]; then
    SYSTEM_SCRIPT=$(find "${SIM_PATH}/lammps" -maxdepth 1 -type f -name '*system*.in' | sort | head -n1)
    if [ -n "$SYSTEM_SCRIPT" ]; then
        {{ mpi_command }} lmp {{ lmp_flags }} -in ${SYSTEM_SCRIPT}
        if [ $? -ne 0 ]; then
            echo "Error: LAMMPS failed on ${SYSTEM_SCRIPT}"
            exit 1
        fi
    fi
fi

{{ mpi_command }} lmp {{ lmp_flags }} -in ${SCRIPT_PATH}
if [ $? -ne 0 ]; then
    echo "Error: LAMMPS failed on ${SCRIPT_PATH}"
    exit 1
fi

{% if use_tmpdir %}
cp -r ${SIM_PATH}/results ${SIM_PATH}/visuals {{ base_dir }}/${SIM_PATH}/
{% endif %}

echo "Simulation completed successfully: ${SIM_PATH}"
