#!/bin/bash
#PBS -l select={{ select_multi if array_size > 1 else select_single }}
#PBS -l walltime={{ walltime }}
{% if array_size > 1 %}
#PBS -J 1-{{ array_size }}
#PBS -o {{ log_dir }}/{{ job_name }}_^array_index^_out.txt
#PBS -e {{ log_dir }}/{{ job_name }}_^array_index^_err.txt
{% else %}
#PBS -o {{ log_dir }}/{{ job_name }}_out.txt
#PBS -e {{ log_dir }}/{{ job_name }}_err.txt
{% endif %}
#PBS -N {{ job_name }}
{% if queue %}
#PBS -q {{ queue }}
{% endif %}
{% if account %}
#PBS -A {{ account }}
{% endif %}

module purge
{% for mod in modules %}
module load {{ mod }}
{% endfor %}

{% if array_size > 1 %}
TASK_ID=${PBS_ARRAY_INDEX}
{% else %}
TASK_ID=1
{% endif %}

SCRIPT_PATH=$(sed -n "${TASK_ID}p" {{ manifest_file }})
SCRIPT_DIR=$(dirname "$SCRIPT_PATH")
SIM_PATH=$(dirname "$SCRIPT_DIR")

if [ -z "$SCRIPT_PATH" ]; then
    echo "Error: No script path for index ${TASK_ID}"
    exit 1
fi

{% if use_tmpdir %}
SIM_ROOT=$(basename "{{ base_dir }}")
SCRATCH={{ scratch_dir }}/${SIM_ROOT}
mkdir -p $SCRATCH/${SIM_PATH}
rsync -av --exclude='*.lammpstrj' {{ base_dir }}/${SIM_PATH}/ $SCRATCH/${SIM_PATH}/
cd $SCRATCH
{% else %}
cd {{ base_dir }}
{% endif %}

{{ mpi_command }} lmp {{ lmp_flags }} -in ${SCRIPT_PATH}
if [ $? -ne 0 ]; then
    echo "Error: LAMMPS failed on ${SCRIPT_PATH}"
    exit 1
fi

{% if use_tmpdir %}
cp -r ${SIM_PATH}/results ${SIM_PATH}/visuals ${SIM_PATH}/data {{ base_dir }}/${SIM_PATH}/
{% endif %}

echo "Simulation completed successfully: ${SIM_PATH}"
